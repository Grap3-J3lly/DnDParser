{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties":
    {
        "languages":
        {
            "type": "array",
            "items":
            [
                {
                    "type": "object",
                    "properties":
                    {
                        "name":
                        {
                            "type": "string",
                            "description": "The 'name' attribute of the language"
                        },
                        "type":
                        {
                            "type":"string",
                            "description": "The 'type' attribute of the language"
                        },
                        "typical_speakers":
                        {
                            "type": "string",
                            "description": "The 'typical_speakers' attribute of the language, concatenated with a comma and space delimiter"
                        },
                        "script":
                        {
                            "type":"string",
                            "description": "The 'script' attribute of the language"
                        },
                        "updated_at":
                        {
                            "type": "string",
                            "format": "date-time",
                            "description": "The 'updated_at' attribute of the language"
                        }
                    },
                    "additionalProperties": false,
                    "required":
                    [
                        "name",
                        "type",
                        "typical_speakers",
                        "script",
                        "updated_at"
                    ]
                }
            ]
        }
    },
    "additionalProperties": false,
    "required":
    [
        "languages"
    ]
}