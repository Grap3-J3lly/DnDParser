{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "properties":
    {
        "damage-types":
        {
            "type": "array",
            "items":
            [
                {
                    "type": "object",
                    "properties":
                    {
                        "name":
                        {
                            "type": "string",
                            "description": "The 'name' attribute of the damage type"
                        },
                        "description":
                        {
                            "type": "string",
                            "description": "The 'description' attribute of the damage type, concatenated with a space delimiter"
                        },
                        "updated_at":
                        {
                            "type": "string",
                            "format": "date-time",
                            "description": "The 'updated_at' attribute of the damage type"
                        }
                    },
                    "additionalProperties": false,
                    "required":
                    [
                        "name",
                        "description",
                        "updated_at"
                    ]
                }
            ]
        }
    },
    "additionalProperties": false,
    "required":
    [
        "damage-types"
    ]
}